# ── .env.example ──────────────────────────────────────────────
# Copy this file to .env and fill in values as needed.

# ── Backend ──────────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
DB_PATH=/data/app.db

# ── Volumes (for local dev reference) ───────────────────────
DB_VOLUME=db_data
REDIS_VOLUME=redis_data

# ── Ports ────────────────────────────────────────────────────
FE_PORT=8080
BE_PORT=3000
REDIS_PORT=6379
PROXY_PORT=80
